	//=======================================================================================================================================
	//            READ INPUTS FROM KP32F
	//=======================================================================================================================================
	REGION READ INPUTS FROM KP32F
	    // Enable test lamp button
	    #internal.panel[#PB_Configuration.itLampTestPbID].boEnable := TRUE;
	    
	    IF NOT "SYS_SimulationActive" THEN
	        // Read push buttons from 0 to 15
	        #readWriteData(itDeviceNumber := #itKP32DeviceNumber,
	                       uiPNIO_SysID := #uiPNIOSysID,
	                       uiSlotNumber := 1,
	                       uiSubSlotNumber := 0,
	                       bo0read_1write := FALSE,
	                       vaModuleSlotData := #internal.buttons0_15);
	        // Read push buttons from 16 to 31
	        #readWriteData(itDeviceNumber := #itKP32DeviceNumber,
	                       uiPNIO_SysID := #uiPNIOSysID,
	                       uiSlotNumber := 2,
	                       uiSubSlotNumber := 0,
	                       bo0read_1write := FALSE,
	                       vaModuleSlotData := #internal.buttons16_31);
	    END_IF;
	    
	    // KP32F management of lamps and buttons
	    FOR #itPushButtonIndexTemp := 0 TO 31 DO
	        
	        (*
	        Push buttons lamp management:
	                OUT:   red      green      blue
	        COLOUR:
	            red         1         0         0
	            green       0         1         0
	            blue        0         0         1
	            yellow      1         1         0
	            white       1         1         1
	            OFF         0         0         0
	            OFF         0         1         1
	            OFF         1         0         1
	        
	        Push buttons order in the panel:
	            07  06  05  04  03  02  01  00
	            15  14  13  12  11  10  09  08
	            23  22  21  20  19  18  17  16
	            31  30  29  28  27  26  25  24
	        *)
	        // Read command button
	        IF NOT "SYS_SimulationActive" THEN
	            CASE #itPushButtonIndexTemp OF
	                0:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB00;
	                1:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB01;
	                2:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB02;
	                3:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB03;
	                4:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB04;
	                5:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB05;
	                6:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB06;
	                7:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB07;
	                8:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB08;
	                9:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB09;
	                10:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB10;
	                11:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB11;
	                12:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB12;
	                13:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB13;
	                14:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB14;
	                15:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons0_15.PB15;
	                16:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB16;
	                17:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB17;
	                18:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB18;
	                19:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB19;
	                20:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB20;
	                21:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB21;
	                22:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB22;
	                23:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB23;
	                24:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB24;
	                25:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB25;
	                26:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB26;
	                27:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB27;
	                28:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB28;
	                29:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB29;
	                30:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB30;
	                31:
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.buttons16_31.PB31;
	                ELSE
	                    #internal.panel[#itPushButtonIndexTemp].boCmdOn := FALSE;
	            END_CASE;
	        ELSE
	            #internal.panel[#itPushButtonIndexTemp].boCmdOn := #internal.simulation[#itPushButtonIndexTemp].boPB;
	        END_IF;
	        #internal.panel[#itPushButtonIndexTemp].boCmdWrong := FALSE;
	        IF NOT #internal.panel[#itPushButtonIndexTemp].boEnable OR #boChgOfModeFiltTemp THEN
	            IF #internal.panel[#itPushButtonIndexTemp].boCmdOn AND NOT #boChgOfModeFiltTemp THEN
	                #internal.panel[#itPushButtonIndexTemp].boCmdWrong := TRUE;
	                #boWrongPushCmdTemp := TRUE;
	            END_IF;
	            #internal.panel[#itPushButtonIndexTemp].boCmdOn := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boSelect := FALSE;
	        END_IF;
	        #internal.panel[#itPushButtonIndexTemp].boCmdRE := #internal.panel[#itPushButtonIndexTemp].boCmdOn AND NOT #internal.panel[#itPushButtonIndexTemp].boCmdMem;
	        #internal.panel[#itPushButtonIndexTemp].boCmdFE := NOT #internal.panel[#itPushButtonIndexTemp].boCmdOn AND #internal.panel[#itPushButtonIndexTemp].boCmdMem;
	        #internal.panel[#itPushButtonIndexTemp].boCmdMem := #internal.panel[#itPushButtonIndexTemp].boCmdOn;
	        
	        IF (#internal.panel[#itPushButtonIndexTemp].itPBType = #PB_EQUIPMENT) AND #internal.panel[#itPushButtonIndexTemp].boCmdRE THEN
	            #internal.panel[#itPushButtonIndexTemp].boSelect := NOT #internal.panel[#itPushButtonIndexTemp].boSelect;
	            FOR #itPushButtonIndex2Temp := 0 TO 31 DO
	                IF (#internal.panel[#itPushButtonIndex2Temp].itPBType = #PB_EQUIPMENT) AND (#itPushButtonIndexTemp <> #itPushButtonIndex2Temp) THEN
	                    #internal.panel[#itPushButtonIndex2Temp].boSelect := FALSE;
	                END_IF;
	            END_FOR;
	            #boResetPBsStatesTemp := TRUE;
	        END_IF;
	        
	    END_FOR;
	END_REGION
	
	
	//=======================================================================================================================================
	//            CAVITY SELECTION
	//=======================================================================================================================================
	REGION CAVITY SELECTION
	    #internal.panel[#PB_Configuration.itLeftSelPbID].boEnable := TRUE;
	    #internal.panel[#PB_Configuration.itRightSelPbID].boEnable := TRUE;
	    #internal.panel[#PB_Configuration.itLeftSelPbID].boAborted := FALSE;
	    #internal.panel[#PB_Configuration.itRightSelPbID].boAborted := FALSE;
	    #internal.panel[#PB_Configuration.itLeftSelPbID].boHeld := FALSE;
	    #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := FALSE;
	    
	    #internal.panel[#PB_Configuration.itOnOffSelPbID].boOnPos := FALSE;
	    #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos := FALSE;
	    #internal.panel[#PB_Configuration.itOutCmdPbID].boOnPos := FALSE;
	    #internal.panel[#PB_Configuration.itUpCmdPbID].boOnPos := FALSE;
	    #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos := FALSE;
