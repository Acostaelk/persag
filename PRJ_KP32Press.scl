	                #internal.panel[#PB_Configuration.itDownCmdPbID].boEnable := #EQunloaderL."to".boEnaUnloaderDown OR #EQunloaderR."to".boEnaUnloaderDown OR #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itDownCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itRetractCmdPbID].boEnable := #EQunloaderL."to".boEnaPaddlesRet OR #EQunloaderR."to".boEnaPaddlesRet OR #internal.panel[#PB_Configuration.itRetractCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itRetractCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itExpandCmdPbID].boEnable := #EQunloaderL."to".boEnaPaddlesExp OR #EQunloaderR."to".boEnaPaddlesExp OR #internal.panel[#PB_Configuration.itExpandCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itExpandCmdPbID].boMoving;
	            END_IF;
	            
	            // Unloaders PCI: manual commands
	            IF #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boSelect THEN
	                #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos := #EQunloaderL."to".boPosExtendRet AND #EQunloaderR."to".boPosExtendRet;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boOnPos := #EQunloaderL."to".boPosExtendExp AND #EQunloaderR."to".boPosExtendExp;
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boOnPos := #EQunloaderL."to".boPosUnloaderUp AND #EQunloaderR."to".boPosUnloaderUp;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos := #EQunloaderL."to".boPosUnloaderDown AND #EQunloaderR."to".boPosUnloaderDown;
	                #internal.panel[#PB_Configuration.itRetractCmdPbID].boOnPos := #EQunloaderL."to".boPosPaddlesRet AND #EQunloaderR."to".boPosPaddlesRet;
	                #internal.panel[#PB_Configuration.itExpandCmdPbID].boOnPos := #EQunloaderL."to".boPosPaddlesExp AND #EQunloaderR."to".boPosPaddlesExp;
	                
	                #internal.panel[#PB_Configuration.itInCmdPbID].boMoving := #EQunloaderL."to".boMoveExtendRet OR #EQunloaderR."to".boMoveExtendRet;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boMoving := #EQunloaderL."to".boMoveExtendExp OR #EQunloaderR."to".boMoveExtendExp;
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boMoving := #EQunloaderL."to".boMoveUnloaderUp AND #EQunloaderR."to".boMoveUnloaderUp;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boMoving := #EQunloaderL."to".boMoveUnloaderDown AND #EQunloaderR."to".boMoveUnloaderDown;
	                #internal.panel[#PB_Configuration.itRetractCmdPbID].boMoving := #EQunloaderL."to".boMovePaddlesRet OR #EQunloaderR."to".boMovePaddlesRet;
	                #internal.panel[#PB_Configuration.itExpandCmdPbID].boMoving := #EQunloaderL."to".boMovePaddlesExp OR #EQunloaderR."to".boMovePaddlesExp;
	                
	                #internal.panel[#PB_Configuration.itInCmdPbID].boEnable := #EQunloaderL."to".boEnaExtendRet OR #EQunloaderR."to".boEnaExtendRet OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boEnable := #EQunloaderL."to".boEnaExtendExp OR #EQunloaderR."to".boEnaExtendExp OR #internal.panel[#PB_Configuration.itOutCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itOutCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boEnable := #EQunloaderL."to".boEnaUnloaderUp OR #EQunloaderR."to".boEnaUnloaderUp OR #internal.panel[#PB_Configuration.itUpCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itUpCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boEnable := #EQunloaderL."to".boEnaUnloaderDown OR #EQunloaderR."to".boEnaUnloaderDown OR #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itDownCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itRetractCmdPbID].boEnable := #EQunloaderL."to".boEnaPaddlesRet OR #EQunloaderR."to".boEnaPaddlesRet OR #internal.panel[#PB_Configuration.itRetractCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itRetractCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itExpandCmdPbID].boEnable := #EQunloaderL."to".boEnaPaddlesExp OR #EQunloaderR."to".boEnaPaddlesExp OR #internal.panel[#PB_Configuration.itExpandCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itExpandCmdPbID].boMoving;
	            END_IF;
	            
	            
	            // Enable push-buttons
	            #internal.panel[#PB_Configuration.itExitConvPbId].boEnable := TRUE;
	            
	            // Modules fault & warning
	            #internal.panel[#PB_Configuration.itExitConvPbId].boAborted := #EQExitConvL."to".boStatusAbortedEQ OR #EQExitConvL."to".boStatusAbortedLwConveyor OR #EQExitConvL."to".boStatusAbortedLwBlocks OR
	            #EQExitConvR."to".boStatusAbortedEQ OR #EQExitConvR."to".boStatusAbortedLwConveyor OR #EQExitConvR."to".boStatusAbortedLwBlocks;
	            #internal.panel[#PB_Configuration.itExitConvPbId].boHeld := #EQExitConvL."to".boStatusHeldEQ OR #EQExitConvL."to".boStatusHeldLwConveyor OR #EQExitConvL."to".boStatusHeldLwBlocks OR
	            #EQExitConvR."to".boStatusHeldEQ OR #EQExitConvR."to".boStatusHeldLwConveyor OR #EQExitConvR."to".boStatusHeldLwBlocks;
	            
	            // Cooling Conveyors : manual commands
	            IF #internal.panel[#PB_Configuration.itExitConvPbId].boSelect THEN
	                #internal.panel[#PB_Configuration.itRightSelPbID].boAborted := #EQExitConvL."to".boStatusAbortedEQ OR #EQExitConvL."to".boStatusAbortedLwConveyor OR #EQExitConvL."to".boStatusAbortedLwBlocks OR
	                #EQExitConvR."to".boStatusAbortedEQ OR #EQExitConvR."to".boStatusAbortedLwConveyor OR #EQExitConvR."to".boStatusAbortedLwBlocks;
	                #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := #EQExitConvL."to".boStatusHeldEQ OR #EQExitConvL."to".boStatusHeldLwConveyor OR #EQExitConvL."to".boStatusHeldLwBlocks OR
	                #EQExitConvR."to".boStatusHeldEQ OR #EQExitConvR."to".boStatusHeldLwConveyor OR #EQExitConvR."to".boStatusHeldLwBlocks;
	                
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boOnPos := #EQExitConvL."to".boPosConveyorUp AND #EQExitConvR."to".boPosLwConveyorUp;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos := #EQExitConvL."to".boPosConveyorDown AND #EQExitConvR."to".boPosLwConveyorDown;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boOnPos := FALSE;
	                #internal.panel[#PB_Configuration.itLockCmdPbID].boOnPos := #EQExitConvL."to".boPosBlockIns AND #EQExitConvR."to".boPosLwBlockIns;
	                #internal.panel[#PB_Configuration.itUnlockCmdPbID].boOnPos := #EQExitConvL."to".boPosBlockRel AND #EQExitConvR."to".boPosLwBlockRel;
	                
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boMoving := #EQExitConvR."to".boMoveConveyorUp OR #EQExitConvR."to".boMoveLwConveyorUp;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boMoving := #EQExitConvR."to".boMoveConveyorDown OR #EQExitConvR."to".boMoveLwConveyorDown;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boMoving := #EQExitConvR."to".boMoveConveyorFwd OR #EQExitConvR."to".boMoveLwConveyorFwd;
	                #internal.panel[#PB_Configuration.itLockCmdPbID].boMoving := #EQExitConvR."to".boMoveBlockIns OR #EQExitConvR."to".boMoveLwBlockIns;
	                #internal.panel[#PB_Configuration.itUnlockCmdPbID].boMoving := #EQExitConvR."to".boMoveBlockRel OR #EQExitConvR."to".boMoveLwBlockRel;
	                
	                #internal.panel[#PB_Configuration.itUpCmdPbID].boEnable := #EQExitConvL."to".boEnaConveyorUp OR #EQExitConvR."to".boEnaLwConveyorUp OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itDownCmdPbID].boEnable := #EQExitConvL."to".boEnaConveyorDown OR #EQExitConvR."to".boEnaLwConveyorDown OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itOutCmdPbID].boEnable := #EQExitConvL."to".boEnaConveyorFwd OR #EQExitConvR."to".boEnaLwConveyorFwd OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itLockCmdPbID].boEnable := #EQExitConvL."to".boEnaBlockIns OR #EQExitConvR."to".boEnaLwBlockIns OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	                #internal.panel[#PB_Configuration.itUnlockCmdPbID].boEnable := #EQExitConvL."to".boEnaBlockRel OR #EQExitConvR."to".boEnaLwBlockRel OR #internal.panel[#PB_Configuration.itInCmdPbID].boOnPos OR #internal.panel[#PB_Configuration.itInCmdPbID].boMoving;
	            END_IF;
	            
	        END_IF;
	    END_REGION
	    
	END_REGION
	
	//=======================================================================================================================================
	//            PRODUCTION PROGRAM AUTO
	//=======================================================================================================================================
	REGION PRODUCTION PROGRAM AUTO    
	   REGION LEFT    
	        IF #internal.boAutoSelOnPressL THEN
	            #internal.panel[#PB_Configuration.itLeftSelPbID].boAborted := #EQgtsL."to".boStatusAbortedEQ OR #EQloaderL."to".boStatusAbortedEQ OR #EQcenterMechL."to".boStatusAbortedEQ OR #EQintHeatL."to".boStatusAbortedEQ OR
	            #EQpressL."to".boStatusAbortedEQ OR #EQextHeatL."to".boStatusAbortedEQ OR #EQunloaderL."to".boStatusAbortedEQ OR #EQExitConvL."to".boStatusAbortedEQ;
	            #internal.panel[#PB_Configuration.itLeftSelPbID].boHeld := #EQgtsL."to".boStatusHeldEQ OR #EQloaderL."to".boStatusHeldEQ OR #EQcenterMechL."to".boStatusHeldEQ OR #EQintHeatL."to".boStatusHeldEQ OR #EQpressL."to".boStatusHeldEQ OR
	            #EQextHeatL."to".boStatusHeldEQ OR #EQunloaderL."to".boStatusHeldEQ OR #EQExitConvL."to".boStatusHeldEQ OR #unitL."to".boMoldDisabled OR #unitL."to".boLoadDisabled;
	            IF #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                REGION LOADER & MGTS & UNIT
	                    #internal.panel[#PB_Configuration.itLoaderPbID].boEnable := TRUE;
	                    #internal.panel[#PB_Configuration.itGTSPbID].boEnable := TRUE;
	                    
	                    IF NOT #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	                        // Modules fault & warning
	                        #internal.panel[#PB_Configuration.itGTSPbID].boAborted := #EQgtsL."to".boStatusAbortedEQ;
	                        #internal.panel[#PB_Configuration.itGTSPbID].boHeld := #EQgtsL."to".boStatusHeldEQ;
	                        #internal.panel[#PB_Configuration.itLoaderPbID].boAborted := #EQloaderL."to".boStatusAbortedEQ;
	                        #internal.panel[#PB_Configuration.itLoaderPbID].boHeld := #EQloaderL."to".boStatusHeldEQ OR #unitL."to".boLoadDisabled;
	                    END_IF;
	                    
	                    // MGTS: automatic command
	                    IF #internal.panel[#PB_Configuration.itGTSPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    END_IF;
	                    
	                    // Loaders: automatic command
	                    IF #internal.panel[#PB_Configuration.itLoaderPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                        // Protection for wrong disable timer
	                        #internal.disableFilterLeft(IN := #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND NOT #internal.boDisableEQLmem,
	                                                   PT := T#2s,
	                                                   Q => #internal.boDisableEQLmem);
	                        
	                        IF #internal.boDisableEQLmem AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                            #unitL.from.boLoadDisableReq := TRUE;
	                        END_IF;
	                    END_IF;
	                    
	                    // Unit procedure commands: pick-up
	                    #internal.panel[#PB_Configuration.itUnitPbID].boEnable := #internal.panel[#PB_Configuration.itUnitPbID].boAborted OR #internal.panel[#PB_Configuration.itUnitPbID].boHeld;
	                    #internal.panel[#PB_Configuration.itPickupPbID].boEnable := #unitL."to".boEnaPickUp OR #internal.panel[#PB_Configuration.itPickupPbID].boAborted; //AND internal.panel[itLeftSelPbID].boSelect;
	                    
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itUnitPbID].boAborted := #unitL."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itPickupPbID].boAborted := #unitL."to".boRescueTireOccured;
	                    #internal.panel[#PB_Configuration.itUnitPbID].boHeld := #unitL."to".boStatusHeldEQ;
	                    
	                    // Pick-up command
	                    IF #internal.panel[#PB_Configuration.itPickupPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                        #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect := #unitL."to".boEnaPickUp AND NOT #unitL."to".boLoadDisabled;
	                        #unitL.from.boPickUpCmd := #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect AND #unitL."to".boEnaPickUp AND NOT #unitL."to".boLoadDisabled;
	                    END_IF;
	   
	                END_REGION
	            
	                REGION PRESSES
	                    #internal.panel[#PB_Configuration.itPressPbID].boEnable := TRUE;
	                    
	                    IF NOT #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	                        // Modules fault & warning
	                        #internal.panel[#PB_Configuration.itPressPbID].boAborted := #EQpressL."to".boStatusAbortedEQ;
	                        #internal.panel[#PB_Configuration.itPressPbID].boHeld := #EQpressL."to".boStatusHeldEQ OR #unitL."to".boMoldDisabled;
	                    END_IF;
	                    
	                    // Press: automatic commands
	                    IF #internal.panel[#PB_Configuration.itPressPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                        IF #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE AND FALSE THEN
	                            #unitL.from.boMoldDisableReq := TRUE;
	                        END_IF;
	                    END_IF;
	                END_REGION
	            
	                REGION CENTER-MECH
	                    #internal.panel[#PB_Configuration.itTopRingPbID].boEnable := TRUE;// internal.panel[itTopRingPbID].boAborted OR internal.panel[itTopRingPbID].boHeld;
	                    #internal.panel[#PB_Configuration.itBotRingPbID].boEnable := TRUE;// internal.panel[itBotRingPbID].boAborted OR internal.panel[itBotRingPbID].boHeld;
	                    #internal.panel[#PB_Configuration.itBeadRingPbID].boEnable := TRUE;// internal.panel[itBeadRingPbID].boAborted OR internal.panel[itBeadRingPbID].boHeld;
	                    
	                    IF NOT #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	                        // Modules fault & warning
	                        #internal.panel[#PB_Configuration.itTopRingPbID].boAborted := #EQcenterMechL."to".boStatusAbortedEQ OR #EQcenterMechL."to".boStatusAbortedTCRing;
	                        #internal.panel[#PB_Configuration.itTopRingPbID].boHeld := #EQcenterMechL."to".boStatusHeldEQ OR #EQcenterMechL."to".boStatusHeldTCRing;
	                        #internal.panel[#PB_Configuration.itBotRingPbID].boAborted := #EQcenterMechL."to".boStatusAbortedEQ OR #EQcenterMechL."to".boStatusAbortedBCRing;
	                        #internal.panel[#PB_Configuration.itBotRingPbID].boHeld := #EQcenterMechL."to".boStatusHeldEQ OR #EQcenterMechL."to".boStatusHeldBCRing;
	                        #internal.panel[#PB_Configuration.itBeadRingPbID].boAborted := #EQcenterMechL."to".boStatusAbortedEQ OR #EQcenterMechL."to".boStatusAbortedBeadRing;
	                        #internal.panel[#PB_Configuration.itBeadRingPbID].boHeld := #EQcenterMechL."to".boStatusHeldEQ OR #EQcenterMechL."to".boStatusHeldBeadRing;
	                    END_IF;
	                    // Top Ring: automatic commands
	                    IF #internal.panel[#PB_Configuration.itTopRingPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    END_IF;
	                    // Bottom Ring: automatic commands
	                    IF #internal.panel[#PB_Configuration.itBotRingPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    END_IF;
	                    // Bead Ring: automatic commands
	                    IF #internal.panel[#PB_Configuration.itBeadRingPbID].boSelect THEN
	                        #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    END_IF;
	                END_REGION
	            
	                REGION UNLOADER & COOLING CONVEYORS
	                #internal.panel[#PB_Configuration.itUnloaderPbID].boEnable := TRUE;
	                #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boEnable := TRUE;
	                #internal.panel[#PB_Configuration.itExitConvPbId].boEnable := TRUE;
	                
	                IF NOT #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itUnloaderPbID].boAborted := #EQunloaderL."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPbID].boHeld := #EQunloaderL."to".boStatusHeldEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boAborted := #EQunloaderL."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boHeld := #EQunloaderL."to".boStatusHeldEQ;
	                    #internal.panel[#PB_Configuration.itExitConvPbId].boAborted := #EQExitConvL."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itExitConvPbId].boHeld := #EQExitConvL."to".boStatusHeldEQ;
	                END_IF;
	                // Unloader: automatic commands
	                IF #internal.panel[#PB_Configuration.itUnloaderPbID].boSelect OR #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    IF #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE THEN
	                        #unitL.from.boUnloadDisableReq := TRUE;
	                    END_IF;
	                END_IF;
	                
	                // Cooling conveyors: automatic commands     
	                IF #internal.panel[#PB_Configuration.itExitConvPbId].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	            END_REGION
	        END_IF;
	        END_IF;
	    END_REGION
	
	    REGION RIGHT
	    IF #internal.boAutoSelOnPressR THEN
	        #internal.panel[#PB_Configuration.itRightSelPbID].boAborted := #EQgtsR."to".boStatusAbortedEQ OR #EQloaderR."to".boStatusAbortedEQ OR #EQcenterMechR."to".boStatusAbortedEQ OR #EQintHeatR."to".boStatusAbortedEQ OR
	        #EQpressR."to".boStatusAbortedEQ OR #EQextHeatR."to".boStatusAbortedEQ OR #EQunloaderR."to".boStatusAbortedEQ OR #EQExitConvR."to".boStatusAbortedEQ;
	        #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := #EQgtsR."to".boStatusHeldEQ OR #EQloaderR."to".boStatusHeldEQ OR #EQcenterMechR."to".boStatusHeldEQ OR #EQintHeatR."to".boStatusHeldEQ OR #EQpressR."to".boStatusHeldEQ OR
	        #EQextHeatR."to".boStatusHeldEQ OR #EQunloaderR."to".boStatusHeldEQ OR #EQExitConvR."to".boStatusHeldEQ OR #unitR."to".boMoldDisabled OR #unitR."to".boLoadDisabled;
	        
	        
	        IF #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	            REGION LOADER & MGTS & UNIT  
	                #internal.panel[#PB_Configuration.itLoaderPbID].boEnable := TRUE;
	                #internal.panel[#PB_Configuration.itGTSPbID].boEnable := TRUE;
	                
	                IF NOT #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itGTSPbID].boAborted := #EQgtsR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itGTSPbID].boHeld := #EQgtsR."to".boStatusHeldEQ;
	                    #internal.panel[#PB_Configuration.itLoaderPbID].boAborted := #EQloaderR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itLoaderPbID].boHeld := #EQloaderR."to".boStatusHeldEQ OR #unitR."to".boLoadDisabled;
	                END_IF;
	                
	                // MGTS: automatic command
	                IF #internal.panel[#PB_Configuration.itGTSPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	                
	                // Loaders: automatic command
	                IF #internal.panel[#PB_Configuration.itLoaderPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    
	                    // Protection for wrong disable timer
	                    #internal.disableFilterRight(IN := #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND NOT #internal.boDisableEQRmem,
	                                                 PT := T#2s,
	                                                 Q => #internal.boDisableEQRmem);
	                    
	                    IF #internal.boDisableEQRmem AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	                        #unitR.from.boLoadDisableReq := TRUE;
	                    END_IF;
	                END_IF;
	                
	                // Unit procedure commands: pick-up
	                #internal.panel[#PB_Configuration.itUnitPbID].boEnable := #internal.panel[#PB_Configuration.itUnitPbID].boAborted OR #internal.panel[#PB_Configuration.itUnitPbID].boHeld;
	                #internal.panel[#PB_Configuration.itPickupPbID].boEnable := #unitR."to".boEnaPickUp OR #internal.panel[#PB_Configuration.itPickupPbID].boAborted; //AND internal.panel[itRightSelPbID].boSelect;
	                
	                // Modules fault & warning
	                #internal.panel[#PB_Configuration.itUnitPbID].boAborted := #unitR."to".boStatusAbortedEQ;
	                #internal.panel[#PB_Configuration.itPickupPbID].boAborted := #unitR."to".boRescueTireOccured;
	                #internal.panel[#PB_Configuration.itUnitPbID].boHeld := #unitR."to".boStatusHeldEQ;
	                
	                // Pick-up command
	                IF #internal.panel[#PB_Configuration.itPickupPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    #internal.panel[#PB_Configuration.itRightSelPbID].boSelect := #unitR."to".boEnaPickUp AND NOT #unitR."to".boLoadDisabled;
	                    #unitR.from.boPickUpCmd := #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect AND #unitR."to".boEnaPickUp AND NOT #unitR."to".boLoadDisabled;
	                END_IF;
	            END_REGION
	            REGION PRESSES
	                #internal.panel[#PB_Configuration.itPressPbID].boEnable := TRUE;
	                
	                IF NOT #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itPressPbID].boAborted := #EQpressR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itPressPbID].boHeld := #EQpressR."to".boStatusHeldEQ OR #unitR."to".boMoldDisabled;
	                END_IF;
	                
	                // Press: automatic commands
	                IF #internal.panel[#PB_Configuration.itPressPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    IF #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE AND FALSE THEN
	                        #unitR.from.boMoldDisableReq := TRUE;
	                    END_IF;
	                END_IF;
	            END_REGION
	            REGION CENTER-MECH
	                #internal.panel[#PB_Configuration.itTopRingPbID].boEnable := TRUE;// internal.panel[itTopRingPbID].boAborted OR internal.panel[itTopRingPbID].boHeld;
	                #internal.panel[#PB_Configuration.itBotRingPbID].boEnable := TRUE;// internal.panel[itBotRingPbID].boAborted OR internal.panel[itBotRingPbID].boHeld;
	                #internal.panel[#PB_Configuration.itBeadRingPbID].boEnable := TRUE;// internal.panel[itBeadRingPbID].boAborted OR internal.panel[itBeadRingPbID].boHeld;
	                
	                IF NOT #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itTopRingPbID].boAborted := #EQcenterMechR."to".boStatusAbortedEQ OR #EQcenterMechR."to".boStatusAbortedTCRing;
	                    #internal.panel[#PB_Configuration.itTopRingPbID].boHeld := #EQcenterMechR."to".boStatusHeldEQ OR #EQcenterMechR."to".boStatusHeldTCRing;
	                    #internal.panel[#PB_Configuration.itBotRingPbID].boAborted := #EQcenterMechR."to".boStatusAbortedEQ OR #EQcenterMechR."to".boStatusAbortedBCRing;
	                    #internal.panel[#PB_Configuration.itBotRingPbID].boHeld := #EQcenterMechR."to".boStatusHeldEQ OR #EQcenterMechR."to".boStatusHeldBCRing;
	                    #internal.panel[#PB_Configuration.itBeadRingPbID].boAborted := #EQcenterMechR."to".boStatusAbortedEQ OR #EQcenterMechR."to".boStatusAbortedBeadRing;
	                    #internal.panel[#PB_Configuration.itBeadRingPbID].boHeld := #EQcenterMechR."to".boStatusHeldEQ OR #EQcenterMechR."to".boStatusHeldBeadRing;
	                END_IF;
	                
	                // Top Ring: automatic commands
	                IF #internal.panel[#PB_Configuration.itTopRingPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	                // Bottom Ring: automatic commands
	                IF #internal.panel[#PB_Configuration.itBotRingPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	                // Bead Ring: automatic commands
	                IF #internal.panel[#PB_Configuration.itBeadRingPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	            END_REGION
	            REGION UNLOADER & COOLING CONVEYORS
	                #internal.panel[#PB_Configuration.itUnloaderPbID].boEnable := TRUE;
	                #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boEnable := TRUE;
	                #internal.panel[#PB_Configuration.itExitConvPbId].boEnable := TRUE;
	                
	                IF NOT #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	                    // Modules fault & warning
	                    #internal.panel[#PB_Configuration.itUnloaderPbID].boAborted := #EQunloaderR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPbID].boHeld := #EQunloaderR."to".boStatusHeldEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boAborted := #EQunloaderR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boHeld := #EQunloaderR."to".boStatusHeldEQ;
	                    #internal.panel[#PB_Configuration.itExitConvPbId].boAborted := #EQExitConvR."to".boStatusAbortedEQ;
	                    #internal.panel[#PB_Configuration.itExitConvPbId].boHeld := #EQExitConvR."to".boStatusHeldEQ;
	                END_IF;
	                
	                // Unloader: automatic commands
	                IF #internal.panel[#PB_Configuration.itUnloaderPbID].boSelect OR #internal.panel[#PB_Configuration.itUnloaderPCIPbID].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                    IF #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE THEN
	                        #unitR.from.boUnloadDisableReq := TRUE;
	                    END_IF;
	                END_IF;
	                
	                IF #internal.panel[#PB_Configuration.itExitConvPbId].boSelect THEN
	                    #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	                END_IF;
	            END_REGION
	        END_IF;
	    END_IF;
	END_REGION
	
	    REGION HEATING (INTERNAL & EXTERNAL)
	    IF #internal.boAutoSelOnHeatingL THEN
	        #internal.panel[#PB_Configuration.itShapingPbID].boEnable := TRUE;
	        #internal.panel[#PB_Configuration.itExtHeatingPbID].boEnable := TRUE;
	        
	        IF NOT #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	            // Unit curing active
	            #internal.panel[#PB_Configuration.itShapingPbID].boMoving := #EQintHeatL."to".boCuringActive;
	            
	            // Unit procedure commands: gym
	            #internal.panel[#PB_Configuration.itGymPbID].boEnable := #unitL."to".boEnaGym OR #unitL."to".boGymActivated;
	            #internal.panel[#PB_Configuration.itGymPbID].boHeld := #unitL."to".boGymActivated AND NOT #internal.panel[#PB_Configuration.itGymPbID].boSelect;
	            #internal.panel[#PB_Configuration.itExtHeatingPbID].boHeld := NOT #unitL."to".boMoldPrewarmDone AND NOT #unitL."to".boMoldDisabled;
	            
	            // External heating pre-warm done
	            #internal.panel[#PB_Configuration.itLeftSelPbID].boHeld := NOT #unitL."to".boMoldPrewarmDone AND NOT #unitL."to".boMoldDisabled;
	        END_IF;
	        
	        IF #internal.panel[#PB_Configuration.itGymPbID].boSelect THEN
	            #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	            #unitL.from.boGymCmd := #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE;
	        END_IF;
	        
	    END_IF;
	    
	    IF #internal.boAutoSelOnHeatingR THEN
	        #internal.panel[#PB_Configuration.itShapingPbID].boEnable := TRUE;
	        #internal.panel[#PB_Configuration.itExtHeatingPbID].boEnable := TRUE;
	        
	        IF NOT #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	            // Unit curing active
	            #internal.panel[#PB_Configuration.itShapingPbID].boMoving := #EQintHeatR."to".boCuringActive;
	            
	            // Unit procedure commands: gym
	            #internal.panel[#PB_Configuration.itGymPbID].boEnable := #unitR."to".boEnaGym OR #unitR."to".boGymActivated;
	            #internal.panel[#PB_Configuration.itGymPbID].boHeld := #unitR."to".boGymActivated AND NOT #internal.panel[#PB_Configuration.itGymPbID].boSelect;
	            #internal.panel[#PB_Configuration.itExtHeatingPbID].boHeld := NOT #unitR."to".boMoldPrewarmDone AND NOT #unitR."to".boMoldDisabled;
	            
	            // External heating pre-warm done
	            #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := NOT #unitR."to".boMoldPrewarmDone AND NOT #unitR."to".boMoldDisabled;
	        END_IF;
	        
	        IF #internal.panel[#PB_Configuration.itGymPbID].boSelect THEN
	            #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := TRUE;
	            #unitR.from.boGymCmd := #internal.panel[#PB_Configuration.itRightSelPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdRE;
	        END_IF;
	    END_IF;
	    
	    IF #internal.boAutoSelOnHeatingL AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect AND
	        #internal.boAutoSelOnHeatingR AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	        // Unit curing active
	        #internal.panel[#PB_Configuration.itShapingPbID].boMoving := #EQintHeatL."to".boCuringActive OR #EQintHeatR."to".boCuringActive;
	        // Unit procedure commands: gym
	        #internal.panel[#PB_Configuration.itGymPbID].boEnable := #unitL."to".boEnaGym OR #unitL."to".boGymActivated OR #unitR."to".boEnaGym OR #unitR."to".boGymActivated;
	        #internal.panel[#PB_Configuration.itGymPbID].boHeld := (#unitL."to".boGymActivated OR #unitR."to".boGymActivated) AND NOT #internal.panel[#PB_Configuration.itGymPbID].boSelect;
	        #internal.panel[#PB_Configuration.itExtHeatingPbID].boHeld := (NOT #unitL."to".boMoldPrewarmDone AND NOT #unitL."to".boMoldDisabled) OR (NOT #unitR."to".boMoldPrewarmDone AND NOT #unitR."to".boMoldDisabled);
	        
	        // External heating pre-warm done
	        #internal.panel[#PB_Configuration.itLeftSelPbID].boHeld := NOT #unitL."to".boMoldPrewarmDone AND NOT #unitL."to".boMoldDisabled;
	        #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := NOT #unitR."to".boMoldPrewarmDone AND NOT #unitR."to".boMoldDisabled;
	    END_IF;
	    
	    //COMMON PART WHEN WE ARE ON BOTH SIDE IN AUTOMATIC AND BOTH SELECTED TO SHOW ALARM ON EACH SIDE PUSHBUTTON
	    //  IF internal.boAutoSelOnPressL AND internal.boAutoSelOnPressR THEN
	    //      internal.panel[itLeftSelPbID].boHeld := EQgtsL."to".boStatusHeldEQ OR EQloaderL."to".boStatusHeldEQ OR EQcenterMechL."to".boStatusHeldEQ OR EQintHeatL."to".boStatusHeldEQ OR EQpressL."to".boStatusHeldEQ OR 
	    //                                              EQextHeatL."to".boStatusHeldEQ OR EQunloaderL."to".boStatusHeldEQ OR EQExitConvL."to".boStatusHeldEQ OR unitL."to".boMoldDisabled OR unitL."to".boLoadDisabled;
	    //      internal.panel[itRightSelPbID].boHeld := EQgtsR."to".boStatusHeldEQ OR EQloaderR."to".boStatusHeldEQ OR EQcenterMechR."to".boStatusHeldEQ OR EQintHeatR."to".boStatusHeldEQ OR EQpressR."to".boStatusHeldEQ OR 
	    //                                               EQextHeatR."to".boStatusHeldEQ OR EQunloaderR."to".boStatusHeldEQ OR EQExitConvR."to".boStatusHeldEQ OR unitR."to".boMoldDisabled OR unitR."to".boLoadDisabled;
	    //  END_IF;
	END_REGION
	
	END_REGION
	
	//=======================================================================================================================================
	//            SETUP PROGRAM
	//=======================================================================================================================================
	REGION SETUP PROGRAM
	    #internal.boSetupProcActiveL := FALSE;
	    IF (#internal.boSetupSelOnHeatingL AND #internal.boSetupSelOnPressL) AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	        
	        // Equipments free manual commands enable
	        #internal.boSetupProcActiveL := #unitL."to".boSetupProcActive;
	        
	        IF NOT #unitL."to".boSetupFreeManualActive THEN
	            // Start bladder change from panel
	            //#internal.panel[#PB_Configuration.itGymPbID].boEnable := #unitL."to".boSetupBladderChangeEna;
	            //#internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := #unitL."to".boSetupBladderChangeEna;
	            #unitL.from.boSetupBladderChangeReq := #internal.panel[#PB_Configuration.itGymPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND #unitL."to".boSetupBladderChangeEna;
	            
	            // Start mold change from panel
	            //#internal.panel[#PB_Configuration.itSegmentsPbID].boEnable := #unitL."to".boSetupMoldChangeEna;
	            //#internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := #unitL."to".boSetupMoldChangeEna;
	            #unitL.from.boSetupMoldChangeReq := #internal.panel[#PB_Configuration.itSegmentsPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND #unitL."to".boSetupMoldChangeEna;
	        END_IF;
	        
	        // Moves to next step or to completation of procedure
	        IF #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect THEN
	            #internal.panel[#PB_Configuration.itNextCmdPbID].boEnable := #unitL."to".boSetupProcActive AND #unitL."to".boSetupProcEnaNextStep;
	            #unitL.from.boSetupProcNextStep := #internal.panel[#PB_Configuration.itNextCmdPbID].boCmdRE;
	        END_IF;
	    END_IF;
	    
	    #internal.boSetupProcActiveR := FALSE;
	    IF (#internal.boSetupSelOnHeatingR AND #internal.boSetupSelOnPressR) AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	        
	        // Equipments free manual commands enable
	        #internal.boSetupProcActiveR := #unitR."to".boSetupProcActive;
	        IF NOT #unitR."to".boSetupFreeManualActive THEN
	            // Start bladder change from panel
	            //#internal.panel[#PB_Configuration.itGymPbID].boEnable := #unitR."to".boSetupBladderChangeEna;
	            //#internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := #unitR."to".boSetupBladderChangeEna;
	            #unitR.from.boSetupBladderChangeReq := #internal.panel[#PB_Configuration.itGymPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND #unitR."to".boSetupBladderChangeEna;
	            
	            // Start mold change from panel
	            //#internal.panel[#PB_Configuration.itSegmentsPbID].boEnable := #unitL."to".boSetupMoldChangeEna;
	            //#internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := #unitL."to".boSetupMoldChangeEna;
	            #unitR.from.boSetupMoldChangeReq := #internal.panel[#PB_Configuration.itSegmentsPbID].boSelect AND #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND #unitR."to".boSetupMoldChangeEna;
	        END_IF;
	        
	        // Moves to next step or to completation of procedure
	        IF #internal.panel[#PB_Configuration.itRightSelPbID].boSelect THEN
	            #internal.panel[#PB_Configuration.itNextCmdPbID].boEnable := #unitR."to".boSetupProcActive AND #unitR."to".boSetupProcEnaNextStep;
	            #unitR.from.boSetupProcNextStep := #internal.panel[#PB_Configuration.itNextCmdPbID].boCmdRE;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION HPU
	    // Enable push-buttons
	    #internal.panel[#PB_Configuration.itHPUPbID].boEnable := TRUE;
	    
	    // Modules fault & warning
	    #internal.panel[#PB_Configuration.itHPUPbID].boAborted := #EQhpu."to".boStatusAbortedEQ;
	    #internal.panel[#PB_Configuration.itHPUPbID].boHeld := #EQhpu."to".boStatusHeldEQ;
	    
	    IF #internal.panel[#PB_Configuration.itHPUPbID].boSelect THEN
	        #internal.panel[#PB_Configuration.itLeftSelPbID].boAborted := #EQhpu."to".boStatusAbortedEQ;
	        #internal.panel[#PB_Configuration.itRightSelPbID].boAborted := #EQhpu."to".boStatusAbortedEQ;
	        #internal.panel[#PB_Configuration.itLeftSelPbID].boHeld := #EQhpu."to".boStatusHeldEQ;
	        #internal.panel[#PB_Configuration.itRightSelPbID].boHeld := #EQhpu."to".boStatusHeldEQ;
	        
	        IF #internal.panel[#PB_Configuration.itHPUPbID].boSelect AND NOT #internal.boHPU_Selected THEN
	            #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect := TRUE;
	            #internal.panel[#PB_Configuration.itRightSelPbID].boSelect := TRUE;
	        END_IF;
	        
	        #internal.panel[#PB_Configuration.itOnOffSelPbID].boOnPos := (#EQhpu."to".boPosPumpRunning AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) AND
	                                                    (#EQhpu."to".boPosPumpRunning AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        #internal.panel[#PB_Configuration.itUpCmdPbID].boOnPos := FALSE;//(#EQhpu."to".boPosHPVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) AND
	                                                 //(#EQhpu."to".boPosHPVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        #internal.panel[#PB_Configuration.itDownCmdPbID].boOnPos := FALSE;//(#EQhpu."to".boPosLPLeftVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) AND
	                                                   //(#EQhpu."to".boPosLPRightVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        
	        #internal.panel[#PB_Configuration.itOnOffSelPbID].boMoving := (#EQhpu."to".boMovePumpRunning AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                     (#EQhpu."to".boMovePumpRunning AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        #internal.panel[#PB_Configuration.itUpCmdPbID].boMoving := FALSE;//(#EQhpu."to".boMoveHPVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                  //(#EQhpu."to".boMoveHPVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        #internal.panel[#PB_Configuration.itDownCmdPbID].boMoving := FALSE;//(#EQhpu."to".boMoveLPLeftVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                    //(#EQhpu."to".boMoveLPRightVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        
	        IF (#internal.boManSelOnPressL AND #internal.boManSelOnPressR) OR (#internal.boSetupSelOnPressL AND #internal.boSetupSelOnPressR) OR
	            (#internal.boSetupProcActiveL AND #internal.boSetupProcActiveR) THEN
	            #internal.panel[#PB_Configuration.itOnOffSelPbID].boEnable := (#EQhpu."to".boEnaPumpRun AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                         (#EQhpu."to".boEnaPumpRun AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	            #internal.panel[#PB_Configuration.itUpCmdPbID].boEnable := FALSE;//(#EQhpu."to".boEnaHPVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                      //(#EQhpu."to".boEnaHPVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	            #internal.panel[#PB_Configuration.itDownCmdPbID].boEnable := FALSE;//(#EQhpu."to".boEnaLPLeftVlvOpen AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect) OR
	                                                        //(#EQhpu."to".boEnaLPRightVlvOpen AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	            
	            #EQhpu.from.boSelected := #internal.panel[#PB_Configuration.itHPUPbID].boSelect;
	            #EQhpu.from.boLeftSideSelected := #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect;
	            #EQhpu.from.boRightSideSelected := #internal.panel[#PB_Configuration.itRightSelPbID].boSelect;
	            #EQhpu.from.boCmdStartHPU := #internal.panel[#PB_Configuration.itOnOffSelPbID].boCmdOn AND (#internal.panel[#PB_Configuration.itLeftSelPbID].boSelect OR #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	            #EQhpu.from.boCmdRequiredOilLPLeft := #internal.panel[#PB_Configuration.itDownCmdPbID].boCmdOn AND #internal.panel[#PB_Configuration.itLeftSelPbID].boSelect;
	            #EQhpu.from.boCmdRequiredOilLPRight := #internal.panel[#PB_Configuration.itDownCmdPbID].boCmdOn AND #internal.panel[#PB_Configuration.itRightSelPbID].boSelect;
	            #EQhpu.from.boCmdRequiredOilHP := #internal.panel[#PB_Configuration.itUpCmdPbID].boCmdOn AND (#internal.panel[#PB_Configuration.itLeftSelPbID].boSelect OR #internal.panel[#PB_Configuration.itRightSelPbID].boSelect);
	        END_IF;
	    END_IF;
	    #internal.boHPU_Selected := #internal.panel[#PB_Configuration.itHPUPbID].boSelect;
	END_REGION
	
	//=======================================================================================================================================
	//            WRITE OUTPUTS TO KP32F
	//=======================================================================================================================================
	REGION WRITE OUTPUTS TO KP32F
	    // Reset all PBs states
	    IF #boResetPBsStatesTemp THEN
	        FOR #itPushButtonIndexTemp := 0 TO 31 DO
	            #internal.panel[#itPushButtonIndexTemp].boHeld := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boAborted := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boMoving := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boOnPos := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boInterlock := FALSE;
	            #internal.panel[#itPushButtonIndexTemp].boDisabled := FALSE;
	            IF (#internal.panel[#itPushButtonIndexTemp].itPBType = #PB_COMMAND) THEN
	                #internal.panel[#itPushButtonIndexTemp].boEnable := FALSE;
	                #internal.panel[#itPushButtonIndexTemp].boSelect := FALSE;
	            END_IF;
	        END_FOR;
	    END_IF;
	    
	    // Wrong button pushed timer
	    #internal.disabledTOF(IN := #boWrongPushCmdTemp,
	                          PT := T#1s,
	                          Q => #internal.boWrongPushCmdFilt);
	    
	    // Test lamp
	    #internal.testLampTON(IN := #internal.panel[#PB_Configuration.itLampTestPbID].boCmdOn AND NOT #internal.boChgOfTestLampIndex,
	                          PT := T#1s,
	                          Q => #internal.boChgOfTestLampIndex);
	    IF NOT #internal.panel[#PB_Configuration.itLampTestPbID].boCmdOn THEN
	        #internal.itTestLampIndex := 0;
	    ELSIF (#internal.itTestLampIndex = 0) THEN
	        #internal.itTestLampIndex := 1;
	    ELSIF #internal.boChgOfTestLampIndex THEN
	        #internal.itTestLampIndex := #internal.itTestLampIndex + 1;
	        IF #internal.itTestLampIndex > 5 THEN
	            #internal.itTestLampIndex := 1;
	        END_IF;
	    END_IF;
	    #boTestLampOn := #internal.panel[#PB_Configuration.itLampTestPbID].boCmdOn;
	    // KP32F management of lamps and buttons
	    FOR #itPushButtonIndexTemp := 0 TO 31 DO
	        
	        (*
	        Push buttons lamp management:
	                OUT:   red      green      blue
	        COLOUR:
	            red         1         0         0
	            green       0         1         0
	            blue        0         0         1
	            yellow      1         1         0
	            white       1         1         1
	            OFF         0         0         0
	            OFF         0         1         1
	            OFF         1         0         1
	        
	        Push buttons order in the panel:
	            07  06  05  04  03  02  01  00
	            15  14  13  12  11  10  09  08
	            23  22  21  20  19  18  17  16
	            31  30  29  28  27  26  25  24
	        *)
	        
	        // Lamp colour of button
	        #boRedLampTemp := FALSE;
	        #boGreenLampTemp := FALSE;
	        #boBlueLampTemp := FALSE;
	        #itColourCodeTemp := #COLOUR_NONE;
	        IF #internal.panel[#itPushButtonIndexTemp].boEnable OR #internal.boWrongPushCmdFilt OR #boChgOfModeFiltTemp THEN
	            IF #internal.panel[#itPushButtonIndexTemp].boCmdWrong AND #internal.boWrongPushCmdFilt THEN
	                #itColourCodeTemp := #ColorCode_Configuration.itDisabledColourCode;
	            ELSIF #boChgOfModeFiltTemp THEN
	                IF #internal.panel[#itPushButtonIndexTemp].boSemiAMode THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itManualColourCode;
	                ELSIF #internal.panel[#itPushButtonIndexTemp].boAutoMode THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itAutomaticColourCode;
	                END_IF;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boInterlock THEN
	                #itColourCodeTemp := #ColorCode_Configuration.itInterlockColourCode;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boAborted THEN
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itFaultColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBFaultColourCode;
	                END_IF;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boHeld THEN
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itWarningColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBWarningColourCode;
	                END_IF;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boMoving THEN
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itMoveColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBMoveColourCode;
	                END_IF;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boOnPos THEN
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itOnPosColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBOnPosColourCode;
	                END_IF;
	            ELSIF #internal.panel[#itPushButtonIndexTemp].boSelect THEN
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itSelectColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBSelectColourCode;
	                END_IF;
	            ELSE
	                IF (#internal.panel[#itPushButtonIndexTemp].itPBType <> #PB_COMMAND) THEN
	                    #itColourCodeTemp := #ColorCode_Configuration.itEnableColourCode;
	                ELSE
	                    #itColourCodeTemp := #ColorCode_Configuration.itCmdPBEnableColourCode;
	                END_IF;
	            END_IF;
	        END_IF;
	        #internal.simulation[#itPushButtonIndexTemp].itColour := #itColourCodeTemp;
	        CASE #itColourCodeTemp OF
	            #COLOUR_RED:
	                #boRedLampTemp := TRUE;
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := FALSE;
	            #COLOUR_GREEN:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := TRUE;
	                #boBlueLampTemp := FALSE;
	            #COLOUR_BLUE:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := TRUE;
	            #COLOUR_YELLOW:
	                #boRedLampTemp := TRUE;
	                #boGreenLampTemp := TRUE;
	                #boBlueLampTemp := FALSE;
	            #COLOUR_WHITE:
	                #boRedLampTemp := TRUE;
	                #boGreenLampTemp := TRUE;
	                #boBlueLampTemp := TRUE;
	            #COLOUR_RED_BLINK:
	                #boRedLampTemp := "SYS_Square1000ms";
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := FALSE;
	            #COLOUR_GREEN_BLINK:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := "SYS_Square1000ms";
	                #boBlueLampTemp := FALSE;
	            #COLOUR_BLUE_BLINK:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := "SYS_Square1000ms";
	            #COLOUR_YELLOW_BLINK:
	                #boRedLampTemp := "SYS_Square1000ms";
	                #boGreenLampTemp := "SYS_Square1000ms";
	                #boBlueLampTemp := FALSE;
	            #COLOUR_WHITE_BLINK:
	                #boRedLampTemp := "SYS_Square1000ms";
	                #boGreenLampTemp := "SYS_Square1000ms";
	                #boBlueLampTemp := "SYS_Square1000ms";
	            #COLOUR_RED_BLINK_FAST:
	                #boRedLampTemp := "SYS_Square500ms";
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := FALSE;
	            #COLOUR_GREEN_BLINK_FAST:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := "SYS_Square500ms";
	                #boBlueLampTemp := FALSE;
	            #COLOUR_BLUE_BLINK_FAST:
	                #boRedLampTemp := FALSE;
	                #boGreenLampTemp := FALSE;
	                #boBlueLampTemp := "SYS_Square500ms";
	            #COLOUR_YELLOW_BLINK_FAST:
