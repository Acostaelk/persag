	            #boPBsAssigmentWrong := TRUE;
	        ELSE
	            FOR #itPushButtonIndex2Temp := 0 TO 31 DO
	                IF (#internal.itPBIDs[#itPushButtonIndexTemp] = #internal.itPBIDs[#itPushButtonIndex2Temp]) AND (#itPushButtonIndexTemp <> #itPushButtonIndex2Temp) THEN
	                    #boPBsAssigmentWrong := TRUE;
	                    EXIT;
	                END_IF;
	            END_FOR;
	        END_IF;
	        IF #boPBsAssigmentWrong THEN
	            EXIT;
	        END_IF;
	    END_FOR;
