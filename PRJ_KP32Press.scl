	                #boGreenLampTemp := "SYS_Square500ms";
	                #boBlueLampTemp := FALSE;
	            #COLOUR_WHITE_BLINK_FAST:
	                #boRedLampTemp := "SYS_Square500ms";
	                #boGreenLampTemp := "SYS_Square500ms";
	                #boBlueLampTemp := "SYS_Square500ms";
	        END_CASE;
	        IF (#internal.itTestLampIndex <> 0) THEN
	            #boRedLampTemp := (#internal.itTestLampIndex = 1) OR (#internal.itTestLampIndex = 4) OR (#internal.itTestLampIndex = 5);
	            #boGreenLampTemp := (#internal.itTestLampIndex = 2) OR (#internal.itTestLampIndex = 4) OR (#internal.itTestLampIndex = 5);
	            #boBlueLampTemp := (#internal.itTestLampIndex = 3) OR (#internal.itTestLampIndex = 5);
	            IF #boRedLampTemp AND NOT #boGreenLampTemp AND NOT #boBlueLampTemp THEN
	                #internal.simulation[#itPushButtonIndexTemp].itColour := #COLOUR_RED;
	            ELSIF NOT #boRedLampTemp AND #boGreenLampTemp AND NOT #boBlueLampTemp THEN
	                #internal.simulation[#itPushButtonIndexTemp].itColour := #COLOUR_GREEN;
	            ELSIF NOT #boRedLampTemp AND NOT #boGreenLampTemp AND #boBlueLampTemp THEN
	                #internal.simulation[#itPushButtonIndexTemp].itColour := #COLOUR_BLUE;
	            ELSIF #boRedLampTemp AND #boGreenLampTemp AND NOT #boBlueLampTemp THEN
	                #internal.simulation[#itPushButtonIndexTemp].itColour := #COLOUR_YELLOW;
	            ELSIF #boRedLampTemp AND #boGreenLampTemp AND #boBlueLampTemp THEN
	                #internal.simulation[#itPushButtonIndexTemp].itColour := #COLOUR_WHITE;
	            END_IF;
	        END_IF;
	        CASE #itPushButtonIndexTemp OF
	            0:
	                #internal.lamps0_15.red00 := #boRedLampTemp;
	                #internal.lamps0_15.green00 := #boGreenLampTemp;
	                #internal.lamps0_15.blue00 := #boBlueLampTemp;
	            1:
	                #internal.lamps0_15.red01 := #boRedLampTemp;
