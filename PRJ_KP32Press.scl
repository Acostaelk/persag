	        #itRetValTemp := FILL(BVAL := #byNullTemp, BLK => #internal.panel);
	    END_IF;
	    #internal.chgModeTOF(IN := #boChangeOfProgPressTemp OR #boChangeOfProgHeatingTemp OR #boChangeOfProgExitConvTemp,
	                         PT := T#1s,
	                         Q => #boChgOfModeFiltTemp);
	    
	#internal.panel[#PB_Configuration.itLoaderPbID].boSemiAMode := #internal.boManSelOnPressL OR #internal.boSetupSelOnPressL OR #internal.boManSelOnPressR OR #internal.boSetupSelOnPressR;
	#internal.panel[#PB_Configuration.itGTSPbID].boSemiAMode := #internal.boManSelOnPressL OR #internal.boSetupSelOnPressL OR #internal.boManSelOnPressR OR #internal.boSetupSelOnPressR;
